# Development image: runs `vitepress dev` with hot reload.
FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then \
        npm ci --no-audit --no-fund; \
    else \
        npm install --no-audit --no-fund; \
    fi

# `docs/` is mounted as a volume in docker-compose for hot reload.
COPY docs ./docs

EXPOSE 5173

CMD ["npm", "run", "docs:dev"]
